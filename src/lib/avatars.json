    "https://api.dicebear.com/9.x/lorelei-neutral/svg?seed={seed}",
    "https://api.dicebear.com/9.x/micah/svg?seed={seed}",
    "https://api.dicebear.com/9.x/miniavs/svg?seed={seed}",
