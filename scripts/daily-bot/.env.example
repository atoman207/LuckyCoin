# Lucky Coin daily-bot -- settings template.
# Copy this file to ".env" (same folder) and fill in the two values below.
# The real .env is git-ignored, so it never gets committed/leaked.

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase SERVICE ROLE key (starts with sb_secret_...). SERVER/SECRET ONLY.
# Find it in: Supabase dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: override the avatar style (defaults to DiceBear "adventurer").
# AVATAR_BASE_URL=https://api.dicebear.com/9.x/adventurer/png
